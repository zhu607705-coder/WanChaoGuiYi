  "tutorial": {
    "title": "新手引导旁白",
    "segments": [
      {
        "segmentId": "tutorial_intro",
        "text": "天下大势，分久必合，合久必分。自秦始皇一统六合，至康熙帝盛世终章，中华文明走过了两千余年的兴衰更替。今日，你将继承天命，率领历代帝王，重塑华夏山河。",
        "trigger": "game_start",
        "priority": 1
      },
      {
        "segmentId": "tutorial_select_emperor",
        "text": "每位帝王皆有独特天赋与治国之策。始皇帝以霸道统六合，汉武帝以武功震四方，唐太宗以仁政治盛世。慎重选择，这将决定你的文明走向。",
        "trigger": "emperor_selection",
        "priority": 1
      },
      {
        "segmentId": "tutorial_first_governance",
        "text": "治理天下，首重民生。轻徭薄赋则民富国强，严刑峻法则秩序井然。平衡各方势力，方为长久之道。",
        "trigger": "first_governance_action",
        "priority": 2
      },
      {
        "segmentId": "tutorial_war_intro",
        "text": "战争是将领智慧与军力强弱的较量。以少胜多者，名垂青史；以众欺寡者，留骂千古。善用计谋，方为上策。",
        "trigger": "first_war",
        "priority": 2
      },
      {
        "segmentId": "tutorial_event_approach",
        "text": "天有不测风云，人有旦夕祸福。历史大事件往往改变文明走向。把握机遇，或可开创盛世；应对失当，则大厦将倾。",
        "trigger": "first_event",
        "priority": 2
      },
      {
        "segmentId": "tutorial_victory",
        "text": "万朝归一，四海升平。你完成了历代帝王未竟之业，天下重归一统！此乃天命所归，实至名归。",
        "trigger": "game_victory",
        "priority": 1
      },
      {
        "segmentId": "tutorial_defeat",
        "text": "大厦倾颓，帝王陨落。天下大势，终非一人所能逆转。然虽败犹荣，你的故事将流传于青史之中。",
        "trigger": "game_defeat",
        "priority": 1
      },
      {
        "segmentId": "tutorial_prosperity",
        "text": "国泰民安，风调雨顺。百姓安居乐业，四方来朝。此乃治世之象，帝王之幸也。",
        "trigger": "prosperity_achieved",
        "priority": 3
      },
      {
        "segmentId": "tutorial_decline",
        "text": "朝政日非，民不聊生。内有奸佞当道，外有强敌环伺。帝国正在衰落，时间所剩无几。",
        "trigger": "decline_started",
        "priority": 1
      },
      {
        "segmentId": "tutorial_unification",
        "text": "天下一统，四海归心。百姓免于战乱之苦，天下享太平之福。此功此德，当铭刻于青史之上。",
        "trigger": "unification_achieved",
        "priority": 1
      }
    ]
  },
